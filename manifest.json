{
  "manifest_version": 3,
  "name": "김대필 (ContextWrite)",
  "version": "1.0.0",
  "description": "사용자의 웹서핑 맥락을 감지하고, 자연스러운 인간의 글로 AI 초안을 변환하는 AI 글쓰기 비서",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://integrate.api.nvidia.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "24": "icons/icon24.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.naver.com/*",
        "https://*.daum.net/*",
        "https://mail.google.com/*",
        "https://*.notion.so/*",
        "https://*.notion.site/*",
        "https://*.saramin.co.kr/*",
        "https://*.jobkorea.co.kr/*",
        "https://*.wanted.co.kr/*",
        "https://*.jasoseol.com/*",
        "https://*.linkareer.com/*",
        "https://*.tistory.com/*",
        "https://*.velog.io/*",
        "https://*.instagram.com/*",
        "https://*.facebook.com/*",
        "https://*.threads.net/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "icons/icon16.png",
        "icons/icon24.png",
        "icons/icon48.png",
        "icons/icon128.png",
        "icons/top_logo.png",
        "icons/flogo.png"
      ],
      "matches": [
        "https://*.naver.com/*",
        "https://*.daum.net/*",
        "https://mail.google.com/*",
        "https://*.notion.so/*",
        "https://*.notion.site/*",
        "https://*.saramin.co.kr/*",
        "https://*.jobkorea.co.kr/*",
        "https://*.wanted.co.kr/*",
        "https://*.jasoseol.com/*",
        "https://*.linkareer.com/*",
        "https://*.tistory.com/*",
        "https://*.velog.io/*",
        "https://*.instagram.com/*",
        "https://*.facebook.com/*",
        "https://*.threads.net/*"
      ]
    }
  ],
  "action": {
    "default_title": "김대필 실행/닫기",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
